NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Rate limiting (Upstash Redis). Crea una DB gratis en https://console.upstash.com
# Si faltan, el rate limiting se desactiva (dev) pero el resto de guards siguen activos.
UPSTASH_REDIS_REST_URL=https://TU-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu-rest-token

# Video demo servido desde Vercel Blob. Si falta, usa /aureo-video.mp4 local (dev).
# Obtén la URL ejecutando: node scripts/upload-video-to-blob.mjs
NEXT_PUBLIC_DEMO_VIDEO_URL=https://TU-STORE.public.blob.vercel-storage.com/aureo-video.mp4

# Demo interactiva estática (proyecto Vercel aparte). Si falta, el CTA "Explora la
# demo tú mismo" no se renderiza. Apunta a la URL de producción de aureo-demo.
NEXT_PUBLIC_DEMO_URL=https://aureo-demo-six.vercel.app

# Token para subir al Blob (solo para correr el script de subida, no en runtime).
# Vercel → Storage → tu Blob store → pestaña .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Secreto compartido con el proyecto aureo-demo (misma env var, mismo valor,
# configurada en ambos proyectos Vercel) para firmar/verificar el token de
# acceso a la demo pública. Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEMO_TOKEN_SECRET=un-secreto-largo-y-aleatorio-compartido-con-aureo-demo
