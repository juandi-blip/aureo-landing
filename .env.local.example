NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Rate limiting (Upstash Redis). Crea una DB gratis en https://console.upstash.com
# Si faltan, el rate limiting se desactiva (dev) pero el resto de guards siguen activos.
UPSTASH_REDIS_REST_URL=https://TU-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu-rest-token

# Video demo servido desde Vercel Blob. Si falta, usa /aureo-video.mp4 local (dev).
# Obtén la URL ejecutando: node scripts/upload-video-to-blob.mjs
NEXT_PUBLIC_DEMO_VIDEO_URL=https://TU-STORE.public.blob.vercel-storage.com/aureo-video.mp4

# Token para subir al Blob (solo para correr el script de subida, no en runtime).
# Vercel → Storage → tu Blob store → pestaña .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
